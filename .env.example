DATABASE_HOST=your_db_host
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=postgres
DATABASE_URL=postgresql://postgres:your_db_password@your_db_host:5432/postgres

